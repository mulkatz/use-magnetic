{
	"name": "use-magnetic",
	"version": "0.8.0",
	"description": "React hook & components for magnetic hover interactions. Zero dependencies, SSR-safe, a11y-first.",
	"type": "module",
	"license": "MIT",
	"author": "Franz Schlögel",
	"homepage": "https://github.com/mulkatz/use-magnetic#readme",
	"bugs": {
		"url": "https://github.com/mulkatz/use-magnetic/issues"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/mulkatz/use-magnetic"
	},
	"keywords": [
		"magnetic",
		"hover",
		"cursor",
		"attraction",
		"react",
		"hook",
		"animation",
		"interaction",
		"ui",
		"awwwards"
	],
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		}
	},
	"sideEffects": false,
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": ["dist"],
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"check": "biome check .",
		"check:fix": "biome check --write .",
		"test": "vitest run",
		"test:watch": "vitest",
		"prepublishOnly": "npm run build"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.0",
		"@testing-library/react": "^16.3.2",
		"@types/react": "^19.0.0",
		"jsdom": "^28.1.0",
		"tsup": "^8.3.0",
		"typescript": "^5.7.0",
		"vitest": "^3.0.0"
	},
	"peerDependencies": {
		"react": ">=19.0.0"
	},
	"engines": {
		"node": ">=18"
	}
}
